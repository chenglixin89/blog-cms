# Copy this file to .env (already gitignored) and tweak the values you want
# to override. Anything not listed falls back to the default in
# docker-compose.yml.

# ----- MySQL -----
# Strong random passwords are recommended for anything beyond local dev.
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=blog_cms
MYSQL_USER=blog
MYSQL_PASSWORD=blog
MYSQL_HOST_PORT=3306

# ----- Backend -----
BACKEND_HOST_PORT=8080

# Must be at least 32 bytes (UTF-8). Generate a fresh one with:
#   openssl rand -base64 48
BLOG_JWT_SECRET=docker-compose-only-secret-change-me-at-least-32-bytes-long
BLOG_JWT_EXPIRE_SECONDS=7200

# Default admin credentials are seeded only when blog_admin_account is empty.
# Existing accounts are NEVER overwritten.
BLOG_AUTH_ADMIN_USERNAME=admin
BLOG_AUTH_ADMIN_PASSWORD=admin123
BLOG_AUTH_ADMIN_NICKNAME=Admin
